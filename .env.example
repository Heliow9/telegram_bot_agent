APP_NAME=Bot Bet 1x2
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ROLE=web

# Web deve ficar false se você rodar scheduler separado.
ENABLE_BACKGROUND_JOBS=false
CREATE_TABLES_ON_STARTUP=true
REQUEST_LOG_ENABLED=true
RUN_POST_DEPLOY_SYNC_ON_STARTUP=false
RUN_MISSED_SUMMARY_RECOVERY_ON_STARTUP=false

# Processos/cache/filas
REDIS_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CACHE_ENABLED=true
CACHE_PREFIX=botbet
CACHE_DEFAULT_TTL_SECONDS=300

# Filtro final de entrada
SIGNAL_MIN_SCORE=0.72
SIGNAL_MIN_PROBABILITY=0.52
SIGNAL_MAX_RISK_PENALTY=0.22

LOG_LEVEL=INFO
LOG_DIR=logs

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHANNEL_CHAT_ID=

SPORTSDB_API_KEY=123
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
FOOTBALL_API_KEY=
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io

TIMEZONE=America/Recife
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ODDS_API_KEY=
ODDS_REGIONS=eu
ODDS_MARKETS=h2h
ODDS_FORMAT=decimal
VALUE_BET_EDGE=0.05

LIVE_MONITOR_ENABLED=true
LIVE_MONITOR_INTERVAL_SECONDS=390
LIVE_MINUTE_CHECKPOINTS=15,30,45,60,75
LIVE_SIGNAL_MIN_SHOTS_DIFF=4
LIVE_SIGNAL_MIN_ON_TARGET_DIFF=2
LIVE_SIGNAL_MIN_POSSESSION_DIFF=8

DATABASE_URL=mysql+pymysql://usuario:senha@host:3306/banco
JWT_SECRET_KEY=troque-essa-chave
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://bot-bet-front.onrender.com
